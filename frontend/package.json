{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "pnpm --filter @ruftech/e2e test",
    "test:e2e:coverage": "pnpm --filter @ruftech/e2e test:coverage",
    "coverage:merge": "node scripts/merge-coverage.js",
    "coverage:all": "pnpm test:coverage && pnpm test:e2e:coverage && pnpm coverage:merge"
  },
  "devDependencies": {
    "eslint": "9.39.2",
    "istanbul-lib-coverage": "3.2.2",
    "istanbul-lib-report": "3.0.1",
    "istanbul-reports": "3.2.0",
    "prettier": "3.8.1",
    "turbo": "2.8.3"
  },
  "packageManager": "pnpm@10.29.1",
  "name": "ruftech-frontend",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}