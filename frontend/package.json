{
  "name": "frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/prerender.js",
    "lint": "eslint .",
    "new": "plop",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "playwright test && node scripts/e2e-coverage.js",
    "test:coverage:all": "npm run test:coverage && npm run test:e2e:coverage && node scripts/merge-coverage.js",
    "upgrade-dependencies": "npx npm-check-updates -u",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tanstack/react-router": "1.158.1",
    "@tanstack/react-router-devtools": "1.158.1",
    "i18next": "25.8.4",
    "motion": "12.33.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.4"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.58.2",
    "@storybook/addon-a11y": "10.2.7",
    "@storybook/addon-docs": "10.2.7",
    "@storybook/react-vite": "10.2.7",
    "@tanstack/router-plugin": "1.158.1",
    "@types/node": "24.10.11",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.3",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.0",
    "eslint-plugin-storybook": "10.2.7",
    "globals": "17.3.0",
    "istanbul-lib-coverage": "3.2.2",
    "istanbul-lib-report": "3.0.1",
    "istanbul-reports": "3.2.0",
    "playwright": "1.58.2",
    "plop": "4.0.5",
    "storybook": "10.2.7",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "v8-to-istanbul": "9.3.0",
    "vite": "npm:rolldown-vite@7.3.1",
    "vitest": "4.0.18"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.3.1"
  }
}
