{
  "name": "ruftech-pass",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --clearScreen false",
    "build": "tsc --noEmit && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && tsx scripts/prerender.js",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.tsx\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ruftech/fonts": "workspace:*",
    "@ruftech/tokens": "workspace:*",
    "@ruftech/http-client": "workspace:*",
    "@ruftech/logger": "workspace:*",
    "@ruftech/ui": "workspace:*",
    "@tanstack/react-router": "1.158.1",
    "@tanstack/react-router-devtools": "1.158.1",
    "i18next": "25.8.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.4"
  },
  "devDependencies": {
    "@ruftech/eslint-config": "workspace:*",
    "@ruftech/ssg": "workspace:*",
    "@ruftech/typescript-config": "workspace:*",
    "@tanstack/router-plugin": "1.158.1",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "@vanilla-extract/vite-plugin": "5.1.4",
    "vite-plugin-svgr": "4.5.0",
    "@vitejs/plugin-react": "5.1.3",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "9.39.2",
    "happy-dom": "20.5.0",
    "tsx": "4.19.4",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}