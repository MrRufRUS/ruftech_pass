{
  "extends": "@ruftech/typescript-config/react-library.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "."
  ],
  "exclude": [
    "node_modules"
  ]
}